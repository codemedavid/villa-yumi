# Supabase — Project → Settings → API (you already have these)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Owner login for /admin (this is the only thing you need to add)
ADMIN_PASSWORD="choose-a-strong-password"

# Optional — random string that signs the admin cookie. Has a built-in
# default, so you can leave it out.
# ADMIN_SECRET="any-random-string"
